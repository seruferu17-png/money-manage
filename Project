<script>
// ══════════════════════════════════════════════════
// ⚙️  KONFIGURASI — GANTI DI SINI
// ══════════════════════════════════════════════════
const API_KEY   = 'AIzaSyDpHCfzQ6ATREgtsHDQ-0i6d4vgzwNJN0w';
const SHEET_ID  = '1Ybpb6FhQfzLekYIGGAwiajgHfQ0hIniAXbgh1k4oddU';
const TARGET_TABUNGAN = 18000000; // sesuaikan dengan target kamu
// Target per bulan (dari SUMMARY B28) — April-Desember = 2jt
const TARGET_PER_BULAN = {
  'April':2000000,'Mei':2000000,'Juni':2000000,'Juli':2000000,
  'Agustus':2000000,'September':2000000,'Oktober':2000000,'November':2000000,'Desember':2000000
};
// ══════════════════════════════════════════════════

const MOS=['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'];
const MONTH_COLORS=['#818cf8','#c084fc','#f472b6','#60a5fa','#34d399','#fb923c','#a78bfa','#4ade80','#fbbf24','#e879f9','#38bdf8','#f87171'];
const FLEX_CATS=['🛵 Transportasi','🚬 Rokok','🍜 Makanan','🛒 Belanja Bulanan','🚿 Gallon','👕 Loundry','📝 Lain-lain','🛍️ Shopping/Belanja','💡 Listrik','📶 Internet','💳 Shopeepay'];

let allRows=[], chartKat=null, chartTab=null, chartTgt=null, toastT, avgDetailData=null;
const CACHE_KEY='mm_data_v1', CACHE_TTL=5*60*1000; // 5 menit

// ── CLOCK ──────────────────────────────────────────
const HARI=['Minggu','Senin','Selasa','Rabu','Kamis','Jumat','Sabtu'];
function updateClock(){
  const n=new Date();
  const el=document.getElementById('hdrTime'), de=document.getElementById('hdrDate');
  if(el) el.textContent=`${pad(n.getHours())}:${pad(n.getMinutes())}:${pad(n.getSeconds())}`;
  if(de) de.textContent=`${HARI[n.getDay()]}, ${n.getDate()} ${MOS[n.getMonth()]} ${n.getFullYear()}`;
}
setInterval(updateClock,1000); updateClock();
function pad(n){return String(n).padStart(2,'0');}

// ── CACHE ──────────────────────────────────────────
function saveCache(data){
  try{localStorage.setItem(CACHE_KEY,JSON.stringify({ts:Date.now(),rows:data}));}catch(e){}
}
function loadCache(){
  try{
    const c=JSON.parse(localStorage.getItem(CACHE_KEY)||'null');
    if(c&&Date.now()-c.ts<CACHE_TTL) return c;
    return null;
  }catch(e){return null;}
}
function isCacheFresh(){const c=loadCache();return c&&c.rows&&c.rows.length>0;}

// ── FETCH DATA ─────────────────────────────────────
async function fetchRows(forceRefresh=false){
  if(!forceRefresh){
    const c=loadCache();
    if(c&&c.rows&&c.rows.length>0){
      allRows=c.rows;
      return {rows:c.rows, fromCache:true};
    }
  }
  const url=`https://sheets.googleapis.com/v4/spreadsheets/${SHEET_ID}/values/DATA!A2:H994?key=${API_KEY}`;
  const r=await fetch(url);
  if(!r.ok) throw new Error('Gagal fetch data: '+r.status);
  const j=await r.json();
  const rows=(j.values||[]).map(row=>({
    tanggal:row[0]||'',
    bulan:row[1]||'',
    kategori:row[2]||'',
    nominal:parseFloat((row[3]||'0').toString().replace(/[^0-9.]/g,''))||0,
    pembayaran:row[4]||'',
    detail:row[5]||'',
    metode:row[6]||'',
    jenis:row[7]||''
  })).filter(r=>r.tanggal&&r.bulan&&r.kategori&&r.nominal>0);
  saveCache(rows);
  allRows=rows;
  return {rows, fromCache:false};
}

// ── INIT ───────────────────────────────────────────
document.addEventListener('DOMContentLoaded',async()=>{
  loadTheme();
  // Set bulan & tahun default
  const now=new Date();
  document.getElementById('dashBulan').value=MOS[now.getMonth()];
  document.getElementById('dashTahun').value=String(now.getFullYear());

  // Cek cache dulu — tampilkan langsung
  const c=loadCache();
  if(c&&c.rows&&c.rows.length>0){
    allRows=c.rows;
    loadDashboard(true); // dari cache, tidak perlu fetch ulang
  }
  // Fetch fresh di background
  try{
    const {rows, fromCache}=await fetchRows(!c);
    allRows=rows;
    if(!fromCache||!c){
      loadDashboard(true);
      toast('✅ Data diperbarui','ok');
    }
  }catch(e){
    if(!allRows.length) showDashError(e.message);
    else toast('⚠️ Menggunakan data cache','');
  }
});

// ── NAV ────────────────────────────────────────────
function goPage(p){
  document.querySelectorAll('.page').forEach(el=>el.classList.remove('on'));
  document.querySelectorAll('.bnav-btn').forEach(el=>el.classList.remove('on'));
  document.getElementById('pg-'+p).classList.add('on');
  document.getElementById('nb-'+p).classList.add('on');
  if(p==='data') renderDataPage();
  if(p==='target') renderTargetPage();
  if(p==='tabungan'&&document.getElementById('tabContent').style.display!=='none') renderTabungan();
}

async function doRefresh(){
  const btn=document.getElementById('btnRefresh');
  btn.classList.add('spin-anim');
  toast('🔄 Memperbarui data...');
  try{
    await fetchRows(true);
    const pg=document.querySelector('.page.on');
    const id=pg?pg.id.replace('pg-',''):'dashboard';
    if(id==='dashboard') loadDashboard(true);
    else if(id==='data') renderDataPage();
    else if(id==='tabungan') renderTabungan();
    else if(id==='target') renderTargetPage();
    toast('✅ Data diperbarui','ok');
  }catch(e){
    toast('❌ '+e.message,'err');
  }
  btn.classList.remove('spin-anim');
}

// ── DASHBOARD ──────────────────────────────────────
function loadDashboard(hasData=false){
  const b=document.getElementById('dashBulan').value;
  const t=document.getElementById('dashTahun').value;
  if(!allRows.length&&!hasData){
    document.getElementById('dashContent').innerHTML=`<div class="skel skel-hero"></div><div class="skel-row"><div class="skel skel-card"></div><div class="skel skel-card"></div><div class="skel skel-card"></div></div><div class="skel skel-chart" style="margin-top:10px"></div>`;
    return;
  }
  const rows=allRows.filter(r=>r.bulan===b&&r.tanggal.includes(t));
  const pemasukan=rows.filter(r=>r.jenis==='Pemasukan').reduce((s,r)=>s+r.nominal,0);
  const pengeluaran=rows.filter(r=>r.jenis==='Pengeluaran').reduce((s,r)=>s+r.nominal,0);
  const kas=pemasukan-pengeluaran;
  // Hitung hari aktif & periode
  const tgls=[...new Set(rows.map(r=>r.tanggal))].sort();
  const activeDays=tgls.length;
  let periodeStr='—';
  if(tgls.length){
    const fmt=s=>{if(!s)return'';const p=s.split(/[-T]/);return`${p[2]}/${p[1]}/${p[0]}`;};
    periodeStr=`${fmt(tgls[0])} — ${fmt(tgls[tgls.length-1])}`;
  }
  const totalDays=activeDays||1;
  // Pengeluaran per kategori (hanya flex)
  const byCat={};
  rows.filter(r=>r.jenis==='Pengeluaran'&&FLEX_CATS.some(fc=>r.kategori===fc)).forEach(r=>{
    byCat[r.kategori]=(byCat[r.kategori]||0)+r.nominal;
  });
  const byCatArr=Object.entries(byCat).map(([k,v])=>({kategori:k,nominal:v})).sort((a,b)=>b.nominal-a.nominal);
  const totalFlex=byCatArr.reduce((s,k)=>s+k.nominal,0);
  const avgHarian=totalFlex/totalDays;
  avgDetailData={totalFleksibel:totalFlex,totalDays,avgHarian,byKategori:byCatArr};

  // Semua kategori pengeluaran untuk chart
  const byCatAll={};
  rows.filter(r=>r.jenis==='Pengeluaran').forEach(r=>{
    byCatAll[r.kategori]=(byCatAll[r.kategori]||0)+r.nominal;
  });
  const byCatAllArr=Object.entries(byCatAll).map(([k,v])=>({kategori:k,nominal:v})).sort((a,b)=>b.nominal-a.nominal);

  const cacheInfo=isCacheFresh()?`<span class="cache-badge">📦 cache</span>`:'';

  document.getElementById('dashContent').innerHTML=`
    <div class="hero-kas">
      <div class="hero-kas-blob"></div><div class="hero-kas-blob2"></div>
      <div class="hk-lbl">💼 Arus Kas — ${b} ${t}${cacheInfo}</div>
      <div class="hk-val" id="d-kas">${rpShort(Math.abs(kas))}</div>
      <div class="hk-periode">${periodeStr}</div>
      <div class="hk-pills">
        <div class="hk-pill g">📥 ${rpShort(pemasukan)}</div>
        <div class="hk-pill r">📤 ${rpShort(pengeluaran)}</div>
      </div>
    </div>
    <div class="stat-row3">
      <div class="stat3 tap-card" onclick="openAvgDetail()">
        <div class="stat3-glow" style="background:radial-gradient(circle,rgba(168,85,247,0.4),transparent)"></div>
        <div class="stat3-ico">📊</div>
        <div class="stat3-val" style="color:#c084fc">${rpShort(avgHarian)}</div>
        <div class="stat3-lbl">Rata²/Hari</div>
      </div>
      <div class="stat3">
        <div class="stat3-glow" style="background:radial-gradient(circle,rgba(96,165,250,0.4),transparent)"></div>
        <div class="stat3-ico">📅</div>
        <div class="stat3-val" style="color:#60a5fa">${activeDays} hari</div>
        <div class="stat3-lbl">Hari Aktif</div>
      </div>
      <div class="stat3">
        <div class="stat3-glow" style="background:radial-gradient(circle,rgba(52,211,153,0.4),transparent)"></div>
        <div class="stat3-ico">🗓️</div>
        <div class="stat3-val" style="color:#34d399">${totalDays} hari</div>
        <div class="stat3-lbl">Periode</div>
      </div>
    </div>
    <div class="sec-lbl">Pengeluaran per Kategori</div>
    <div class="chart-card"><canvas id="chartKat" height="220"></canvas></div>
    <div class="sec-lbl">Komposisi</div>
    <div id="budgetList" class="bud-list"></div>
  `;
  setTimeout(()=>{
    countUpShort('d-kas',Math.abs(kas),kas<0?'−':'');
    renderChartKat(byCatAllArr);
    renderBudget(byCatAllArr);
  },50);
}

function showDashError(msg){
  document.getElementById('dashContent').innerHTML=`<div class="empty"><div class="ei">❌</div><p>${msg||'Gagal memuat data'}</p><p style="margin-top:8px;font-size:0.72rem">Pastikan API_KEY & SHEET_ID sudah diisi dengan benar</p></div>`;
}

// ── CHART KATEGORI ─────────────────────────────────
function renderChartKat(byCat){
  const wrap=document.getElementById('chartKat');if(!wrap)return;
  if(!byCat.length){wrap.parentElement.innerHTML='<div class="empty"><div class="ei">📊</div><p>Belum ada pengeluaran</p></div>';return;}
  const ctx=wrap.getContext('2d');
  if(chartKat) chartKat.destroy();
  const colors=['#a78bfa','#f472b6','#60a5fa','#fb923c','#34d399','#818cf8','#fbbf24','#4ade80','#f87171','#e879f9','#38bdf8','#a3e635'];
  const total=byCat.reduce((s,k)=>s+k.nominal,0);
  const isDark=document.documentElement.getAttribute('data-theme')!=='ocean';
  const borderCol=isDark?'rgba(20,15,50,0.85)':'rgba(10,40,90,0.85)';
  const centerPlugin={id:'ctr',beforeDraw(chart){
    const {ctx:c,chartArea:ca}=chart;if(!ca)return;
    const cx=(ca.left+ca.right)/2,cy=(ca.top+ca.bottom)/2;
    c.save();c.textAlign='center';c.textBaseline='middle';
    c.fillStyle='rgba(255,255,255,0.5)';c.font=`500 11px 'DM Sans',sans-serif`;c.fillText('Total',cx,cy-13);
    c.fillStyle='rgba(255,255,255,0.95)';c.font=`bold 22px 'Playfair Display',serif`;
    c.fillText(rpShort(total),cx,cy+10);c.restore();
  }};
  chartKat=new Chart(ctx,{type:'doughnut',plugins:[centerPlugin],
    data:{labels:byCat.map(k=>k.kategori),datasets:[{data:byCat.map(k=>k.nominal),
      backgroundColor:colors.slice(0,byCat.length),borderWidth:2,borderRadius:0,hoverOffset:6,spacing:2,borderColor:borderCol}]},
    options:{responsive:true,cutout:'55%',plugins:{
      legend:{position:'right',labels:{boxWidth:8,boxHeight:8,borderRadius:4,font:{size:10,family:'DM Sans'},
        color:'rgba(255,255,255,0.75)',padding:8,
        generateLabels(chart){const ds=chart.data.datasets[0];
          return chart.data.labels.map((lbl,i)=>({
            text:`${lbl.length>12?lbl.slice(0,11)+'…':lbl}  ${Math.round(ds.data[i]/total*100)}%`,
            fillStyle:colors[i%colors.length],strokeStyle:'transparent',lineWidth:0,index:i,hidden:false
          }));}}},
      tooltip:{callbacks:{label:c=>` ${c.label}: ${rp(c.raw)} (${Math.round(c.raw/total*100)}%)`}}
    }}
  });
}

function renderBudget(byCat){
  const el=document.getElementById('budgetList');if(!el)return;
  if(!byCat.length){el.innerHTML='<div class="empty"><div class="ei">✅</div><p>Belum ada pengeluaran</p></div>';return;}
  const total=byCat.reduce((s,k)=>s+k.nominal,0);
  el.innerHTML=byCat.map(k=>{
    const pct=total>0?Math.round(k.nominal/total*100):0;
    const cls=pct>=30?'bud-over':pct>=15?'bud-warn':'bud-ok';
    return `<div class="bud-item">
      <div class="bud-top"><span class="bud-name">${k.kategori}</span><span class="bud-pct">${pct}%</span></div>
      <div class="bud-bar"><div class="bud-fill ${cls}" style="width:${pct}%"></div></div>
      <div class="bud-amts"><span>${rpShort(k.nominal)}</span><span>dari ${rpShort(total)}</span></div>
    </div>`;
  }).join('');
}

// ── DATA PAGE ──────────────────────────────────────
function renderDataPage(){
  filterData();
}

function filterData(){
  const s=document.getElementById('srch').value.toLowerCase();
  const b=document.getElementById('fBulan').value;
  const j=document.getElementById('fJenis').value;
  const filtered=allRows.filter(r=>
    (!s||[r.kategori,r.detail,r.metode,r.pembayaran,r.bulan].join(' ').toLowerCase().includes(s))&&
    (!b||r.bulan===b)&&(!j||r.jenis===j)
  );
  renderCards(filtered);
}

function renderCards(rows){
  const el=document.getElementById('dataList');
  if(!rows.length){el.innerHTML='<div class="empty"><div class="ei">📋</div><p>Belum ada data</p></div>';return;}
  const sorted=[...rows].sort((a,b)=>b.tanggal.localeCompare(a.tanggal));
  const totMasuk=rows.filter(r=>r.jenis==='Pemasukan').reduce((s,r)=>s+r.nominal,0);
  const totKeluar=rows.filter(r=>r.jenis==='Pengeluaran').reduce((s,r)=>s+r.nominal,0);
  const kas=totMasuk-totKeluar;
  const strip=`<div class="data-summary">
    <div class="ds-item"><div class="ds-lbl">Masuk</div><div class="ds-val g">${rpShort(totMasuk)}</div></div>
    <div class="ds-sep"></div>
    <div class="ds-item"><div class="ds-lbl">Keluar</div><div class="ds-val r">${rpShort(totKeluar)}</div></div>
    <div class="ds-sep"></div>
    <div class="ds-item"><div class="ds-lbl">Kas</div><div class="ds-val ${kas>=0?'g':'r'}">${kas<0?'−':'+'}${rpShort(Math.abs(kas))}</div></div>
  </div>`;
  const grouped={};
  sorted.forEach(r=>{if(!grouped[r.tanggal])grouped[r.tanggal]=[];grouped[r.tanggal].push(r);});
  const groupedHtml=Object.entries(grouped).map(([tgl,txs])=>{
    const dayKas=txs.reduce((s,r)=>r.jenis==='Pemasukan'?s+r.nominal:s-r.nominal,0);
    const kartu=txs.map(r=>{
      const isIn=r.jenis==='Pemasukan',cls=isIn?'inc':'spd',arrow=isIn?'↓':'↑';
      return `<div class="dc ${cls}">
        <div class="dc-row1">
          <div><div class="dc-kat">${r.kategori}</div></div>
          <div class="dc-right">
            <div class="dc-nom ${cls}">${arrow} ${rp(r.nominal)}</div>
            <div class="dc-badge ${cls}">${isIn?'📥':'📤'} ${r.jenis}</div>
          </div>
        </div>
        <div class="dc-tags">
          ${r.pembayaran?`<span class="dtag">💳 ${r.pembayaran}</span>`:''}
          ${r.metode?`<span class="dtag">🏦 ${r.metode}</span>`:''}
          ${r.bulan?`<span class="dtag">📆 ${r.bulan}</span>`:''}
        </div>
        ${r.detail?`<div class="dc-ket">📝 ${r.detail}</div>`:''}
      </div>`;
    }).join('');
    return `<div class="date-group">
      <div class="dg-header">
        <div class="dg-dot"></div>
        <span class="dg-date">📅 ${formatTgl(tgl)}</span>
        <span class="dg-kas ${dayKas>=0?'g':'r'}">${dayKas>=0?'+':''}${rp(dayKas)}</span>
      </div>
      <div class="dg-cards">${kartu}</div>
    </div>`;
  }).join('');
  el.innerHTML=strip+groupedHtml;
}

// ── TABUNGAN ───────────────────────────────────────
function showTab(){
  document.getElementById('tabLock').style.display='none';
  document.getElementById('tabContent').style.display='block';
  renderTabungan();
}
function hideTab(){
  document.getElementById('tabContent').style.display='none';
  document.getElementById('tabLock').style.display='block';
}
function renderTabungan(){
  const tabPerBulan={};
  allRows.forEach(r=>{
    if(r.jenis==='Pengeluaran'&&r.kategori&&r.kategori.toLowerCase().includes('tabungan')){
      tabPerBulan[r.bulan]=(tabPerBulan[r.bulan]||0)+r.nominal;
    }
  });
  const bulanData=MOS.map(bln=>({
    bulan:bln,
    tabungan:tabPerBulan[bln]||0,
    target:TARGET_PER_BULAN[bln]||0
  })).filter(b=>b.tabungan>0||b.target>0);
  const totalTab=Object.values(tabPerBulan).reduce((s,v)=>s+v,0);
  const pct=TARGET_TABUNGAN>0?Math.min(Math.round(totalTab/TARGET_TABUNGAN*100),100):0;
  document.getElementById('tabTotal').textContent=rp(TARGET_TABUNGAN);
  const sub=document.getElementById('tabSub');
  if(sub) sub.textContent=`Terkumpul: ${rp(totalTab)} · ${pct}% tercapai`;
  const fill=document.getElementById('tabBarFill');
  if(fill) setTimeout(()=>fill.style.width=pct+'%',100);
  const el=document.getElementById('tabList');
  if(!bulanData.length){el.innerHTML='<div class="empty"><div class="ei">🏦</div><p>Belum ada data tabungan</p></div>';return;}
  el.innerHTML=bulanData.map((b,i)=>{
    const p2=b.target>0?Math.min(Math.round(b.tabungan/b.target*100),100):0;
    const done=b.target>0&&b.tabungan>=b.target;
    const color=MONTH_COLORS[MOS.indexOf(b.bulan)%MONTH_COLORS.length];
    return `<div class="tab-item">
      <div class="tab-row"><span class="tab-mo">${done?'✅':'⬜'} ${b.bulan}</span><span class="tab-pc" style="color:${color}">${p2}%</span></div>
      <div class="tab-bar"><div class="tab-bar-fill" style="width:${p2}%;background:${color}"></div></div>
      <div class="tab-amts">
        <div class="tab-amt-item"><div class="tab-amt-lbl">Tabungan</div><div class="tab-amt-val">${rpShort(b.tabungan)}</div></div>
        <div class="tab-amt-item"><div class="tab-amt-lbl">Target</div><div class="tab-amt-val">${rpShort(b.target)}</div></div>
      </div>
    </div>`;
  }).join('');
  // Chart tabungan
  const ctx=document.getElementById('chartTab');if(!ctx)return;
  if(chartTab) chartTab.destroy();
  const tc=ctx.getContext('2d');
  chartTab=new Chart(tc,{type:'bar',
    data:{labels:bulanData.map(b=>b.bulan.slice(0,3)),datasets:[
      {label:'✅ Tabungan',data:bulanData.map(b=>b.tabungan),backgroundColor:'rgba(52,211,153,0.6)',borderColor:'#34d399',borderWidth:2,borderRadius:6},
      {label:'🎯 Target',data:bulanData.map(b=>b.target),type:'line',borderColor:'#a855f7',pointRadius:3,fill:false,tension:0.3,borderDash:[5,4]}
    ]},
    options:{responsive:true,plugins:{legend:{position:'bottom',labels:{boxWidth:10,font:{size:10},color:'rgba(255,255,255,0.5)'}}},
      scales:{y:{ticks:{callback:v=>rpShort(v),color:'rgba(255,255,255,0.5)',font:{size:10}},grid:{color:'rgba(255,255,255,0.06)'},border:{display:false}},
        x:{ticks:{color:'rgba(255,255,255,0.5)',font:{size:10}},grid:{display:false},border:{display:false}}}}
  });
}

// ── TARGET ─────────────────────────────────────────
function renderTargetPage(){
  const tabPerBulan={};
  allRows.forEach(r=>{
    if(r.jenis==='Pengeluaran'&&r.kategori&&r.kategori.toLowerCase().includes('tabungan')){
      tabPerBulan[r.bulan]=(tabPerBulan[r.bulan]||0)+r.nominal;
    }
  });
  const months=Object.keys(TARGET_PER_BULAN);
  const el=document.getElementById('tgtContent');
  el.innerHTML=months.map(m=>{
    const tgt=TARGET_PER_BULAN[m],real=tabPerBulan[m]||0,done=real>=tgt;
    const pct=tgt>0?Math.min(Math.round(real/tgt*100),100):0;
    const color=MONTH_COLORS[MOS.indexOf(m)%MONTH_COLORS.length];
    return `<div class="tgt-cur-item">
      <div class="tgt-cur-top">
        <span class="tgt-cur-mo">${done?'✅':'⬜'} ${m}</span>
        <span class="tgt-cur-val" style="color:${color}">${rpShort(tgt)}</span>
      </div>
      <div class="tgt-cur-bar"><div class="tgt-cur-bar-fill" style="width:${pct}%;background:${color}"></div></div>
      <div class="tgt-cur-real">Realisasi: ${rpShort(real)} · ${pct}% tercapai</div>
    </div>`;
  }).join('');
  // Chart target
  const ctx=document.getElementById('chartTgt');if(!ctx)return;
  if(chartTgt) chartTgt.destroy();
  const tc=ctx.getContext('2d');
  chartTgt=new Chart(tc,{type:'bar',
    data:{labels:months.map(m=>m.slice(0,3)),datasets:[
      {label:'🎯 Target',data:months.map(m=>TARGET_PER_BULAN[m]),backgroundColor:'rgba(168,85,247,0.35)',borderColor:'rgba(168,85,247,0.9)',borderWidth:2,borderRadius:6,borderSkipped:false},
      {label:'✅ Realisasi',data:months.map(m=>tabPerBulan[m]||0),backgroundColor:'rgba(52,211,153,0.35)',borderColor:'rgba(52,211,153,0.9)',borderWidth:2,borderRadius:6,borderSkipped:false}
    ]},
    options:{responsive:true,plugins:{
      legend:{position:'bottom',labels:{boxWidth:10,font:{size:10},color:'rgba(255,255,255,0.5)'}},
      tooltip:{callbacks:{label:c=>` ${c.dataset.label}: ${rp(c.raw)}`}}
    },
    scales:{y:{ticks:{callback:v=>rpShort(v),color:'rgba(255,255,255,0.5)',font:{size:10}},grid:{color:'rgba(255,255,255,0.06)'},border:{display:false}},
      x:{ticks:{color:'rgba(255,255,255,0.5)',font:{size:10}},grid:{display:false},border:{display:false}}}}
