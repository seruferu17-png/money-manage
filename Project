/* BOTTOM NAV */
.bnav{position:fixed;bottom:0;left:0;right:0;height:58px;background:rgba(15,12,41,0.92);border-top:1px solid rgba(255,255,255,0.1);display:flex;align-items:stretch;z-index:300;box-shadow:0 -4px 24px rgba(0,0,0,0.5);padding-bottom:env(safe-area-inset-bottom);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px)}
