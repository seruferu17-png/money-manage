<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>💰 SE_REAL — Money Manager</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
/* ── CONFIG — GANTI DI SINI ── */
/* API_KEY dan SHEET_ID diisi di bagian JS di bawah */

:root{
  --bg:#0f0c29;--bg2:#1a1640;
  --sur:rgba(255,255,255,0.08);--sur2:rgba(255,255,255,0.05);
  --bdr:rgba(255,255,255,0.1);--bdr2:rgba(255,255,255,0.18);
  --tx:#FFFFFF;--tx2:#C4B8F0;--tx3:#8878C0;
  --ac:#a855f7;--ac2:#ec4899;--glow:rgba(168,85,247,0.35);
  --grn:#34d399;--grn-bg:rgba(52,211,153,0.15);
  --red:#f87171;--red-bg:rgba(248,113,113,0.15);
  --blu:#60a5fa;--blu-bg:rgba(96,165,250,0.15);
  --inc:rgba(52,211,153,0.1);--spd:rgba(248,113,113,0.1);
  --r:16px;--rsm:12px;--rxs:8px;
  --s1:0 2px 12px rgba(0,0,0,0.3);
  --s2:0 6px 24px rgba(0,0,0,0.4);
  --s3:0 16px 48px rgba(0,0,0,0.5);
  --sa:0 6px 24px var(--glow);
  --ffd:'Playfair Display',Georgia,serif;
  --ffb:'DM Sans',sans-serif;
  --ease:cubic-bezier(.4,0,.2,1);
  --glass:rgba(255,255,255,0.08);
  --glass-bdr:rgba(255,255,255,0.15);
}
[data-theme="ocean"]{
  --bg:#0c3460;--bg2:#0a4a8c;
  --sur:rgba(255,255,255,0.1);--sur2:rgba(255,255,255,0.07);
  --bdr:rgba(255,255,255,0.12);--bdr2:rgba(255,255,255,0.22);
  --tx2:#B8DEFF;--tx3:#7AAED0;
  --ac:#38bdf8;--ac2:#0ea5e9;--glow:rgba(56,189,248,0.35);
  --grn-bg:rgba(52,211,153,0.18);--red-bg:rgba(248,113,113,0.18);
  --inc:rgba(52,211,153,0.12);--spd:rgba(248,113,113,0.12);
  --glass:rgba(255,255,255,0.1);--glass-bdr:rgba(255,255,255,0.2);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{overflow-x:hidden;overflow-y:hidden;width:100%;height:100%;background:#0f0c29;position:fixed;inset:0}
body{overflow-x:hidden;overflow-y:auto;-webkit-overflow-scrolling:touch;width:100%;height:100%;font-family:var(--ffb);background:var(--bg);color:var(--tx);-webkit-font-smoothing:antialiased;-webkit-text-size-adjust:100%;overscroll-behavior-x:none;touch-action:pan-y}
button,a,input,select,textarea{touch-action:manipulation;-webkit-tap-highlight-color:transparent;font-family:var(--ffb)!important}
input,select,textarea{font-size:16px!important}
#app{width:100%;overflow-x:hidden;display:flex;flex-direction:column;min-height:100%;position:relative;z-index:1}

/* COSMIC BG */
#cosmicBg{display:none;position:fixed;inset:0;z-index:0;pointer-events:none;overflow:hidden}
#cosmicBg .cb-grad{position:absolute;inset:0;background:linear-gradient(160deg,#0f0c29 0%,#302b63 50%,#24243e 100%)}
#cosmicBg .cb-blob1{position:absolute;width:320px;height:320px;border-radius:50%;background:radial-gradient(circle,rgba(139,92,246,0.22) 0%,transparent 70%);top:-80px;left:-80px}
#cosmicBg .cb-blob2{position:absolute;width:280px;height:280px;border-radius:50%;background:radial-gradient(circle,rgba(236,72,153,0.16) 0%,transparent 70%);top:30%;right:-60px}
#cosmicBg .cb-blob3{position:absolute;width:220px;height:220px;border-radius:50%;background:radial-gradient(circle,rgba(59,130,246,0.14) 0%,transparent 70%);bottom:15%;left:20px}
:root #cosmicBg{display:block}
[data-theme="ocean"] #cosmicBg{display:none}

/* SKELETON */
@keyframes shimmer{0%{background-position:-200% 0}100%{background-position:200% 0}}
.skel{background:linear-gradient(90deg,rgba(255,255,255,0.06) 25%,rgba(255,255,255,0.12) 50%,rgba(255,255,255,0.06) 75%);background-size:200% 100%;animation:shimmer 1.5s infinite;border-radius:var(--rsm)}
.skel-hero{height:140px;border-radius:20px;margin-bottom:10px;width:100%}
.skel-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;margin-bottom:10px}
.skel-card{height:80px;border-radius:var(--rsm)}
.skel-line{height:14px;margin-bottom:8px;border-radius:50px}
.skel-line.w60{width:60%}
.skel-line.w40{width:40%}
.skel-chart{height:220px;border-radius:var(--rsm)}
.skel-item{height:70px;border-radius:var(--rsm);margin-bottom:6px}

/* HEADER */
.hdr{color:#fff;height:52px;padding:0 28px 0 10px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:200;gap:4px;width:100%;max-width:100%}
:root .hdr{background:rgba(15,12,41,0.88);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid rgba(255,255,255,0.1)}
[data-theme="ocean"] .hdr{background:rgba(10,60,120,0.92);backdrop-filter:blur(20px);border-bottom:1px solid rgba(255,255,255,0.15)}
.hdr-left{display:flex;align-items:center;gap:7px;flex-shrink:0}
.brand-ico{width:26px;height:26px;border-radius:8px;background:linear-gradient(135deg,rgba(168,85,247,0.9),rgba(236,72,153,0.9));display:flex;align-items:center;justify-content:center;font-size:0.82rem;flex-shrink:0;border:1px solid rgba(255,255,255,0.3)}
[data-theme="ocean"] .brand-ico{background:linear-gradient(135deg,#1E7CDA,#0A4A8C)}
.brand-name{font-family:var(--ffd);font-size:0.88rem;font-weight:700;white-space:nowrap}
:root .brand-name{background:linear-gradient(90deg,#c084fc,#f472b6);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
[data-theme="ocean"] .brand-name{background:none;-webkit-text-fill-color:#fff;color:#fff}
.hdr-clock{flex:1;text-align:center;min-width:0;padding:0 4px;overflow:hidden}
.hdr-clock-time{font-size:0.82rem;font-weight:700;color:#fff;letter-spacing:0.03em;line-height:1.2}
.hdr-clock-date{font-size:0.55rem;color:rgba(255,255,255,0.55);font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.hdr-right{display:flex;align-items:center;gap:5px;flex-shrink:0}
.hico{width:30px;height:30px;min-width:30px;border-radius:50%;background:rgba(255,255,255,0.14);border:1px solid rgba(255,255,255,0.28);color:#fff;font-size:0.78rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .18s;flex-shrink:0}
.hico:active{opacity:0.7}
.hico-refresh{font-size:0.9rem}
.hico-refresh.spin-anim{animation:sp .7s linear infinite}

/* MAIN */
.main{flex:1;padding:10px 28px 70px 10px;overflow-x:hidden;width:100%;box-sizing:border-box;touch-action:pan-y}
.page{display:none;animation:pgin .22s var(--ease);width:100%;overflow-x:hidden;box-sizing:border-box;touch-action:pan-y;min-width:0}
.page.on{display:block}
@keyframes pgin{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
.pg-hd{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:10px;gap:6px;min-width:0}
.pg-title{font-family:var(--ffd);font-size:1.2rem;line-height:1.2;color:#fff}
.pg-sub{font-size:0.62rem;color:var(--tx3);font-weight:700;letter-spacing:0.08em;text-transform:uppercase;margin-top:2px}
.period-sel{display:flex;gap:5px;flex-shrink:0}
.spill{height:26px;padding:0 8px;border-radius:50px;border:1.5px solid var(--bdr2);background:var(--sur);color:#fff;font-family:var(--ffb)!important;font-size:16px;font-weight:700;cursor:pointer;appearance:none;-webkit-appearance:none;zoom:0.75}
.sec-lbl{font-size:0.62rem;font-weight:800;color:var(--tx3);text-transform:uppercase;letter-spacing:0.12em;margin:16px 0 8px;display:flex;align-items:center;gap:6px;min-width:0}
.sec-lbl::after{content:'';flex:1;height:1px;background:var(--bdr2)}

/* HERO KAS */
.hero-kas{border-radius:20px;padding:18px 16px 16px;margin-bottom:10px;position:relative;overflow:hidden;box-shadow:0 8px 32px rgba(168,85,247,0.35);width:100%;box-sizing:border-box}
:root .hero-kas{background:linear-gradient(135deg,#4c1d95 0%,#7c3aed 40%,#be185d 100%)}
[data-theme="ocean"] .hero-kas{background:linear-gradient(135deg,#0A4A8C 0%,#1060B8 50%,#1E7CDA 100%);box-shadow:0 8px 24px rgba(16,96,184,0.45)}
.hero-kas-blob{position:absolute;top:-30px;right:-30px;width:120px;height:120px;border-radius:50%;background:rgba(255,255,255,0.09);pointer-events:none}
.hero-kas-blob2{position:absolute;bottom:-20px;left:30px;width:80px;height:80px;border-radius:50%;background:rgba(255,255,255,0.05);pointer-events:none}
.hk-lbl{font-size:0.6rem;font-weight:800;color:rgba(255,255,255,0.75);text-transform:uppercase;letter-spacing:0.12em;margin-bottom:5px}
.hk-val{font-family:var(--ffd);font-size:2rem;font-weight:700;color:#fff;line-height:1;margin-bottom:5px;word-break:break-word}
.hk-periode{font-size:0.64rem;color:rgba(255,255,255,0.65);margin-bottom:10px}
.hk-pills{display:flex;gap:6px;flex-wrap:wrap;width:100%;box-sizing:border-box}
.hk-pill{display:inline-flex;align-items:center;gap:4px;padding:3px 8px;border-radius:50px;font-size:0.66rem;font-weight:700;border:1px solid rgba(255,255,255,0.28);background:rgba(255,255,255,0.14);color:#fff;flex-shrink:0}
.hk-pill.g{background:rgba(52,211,153,0.22);border-color:rgba(52,211,153,0.45);color:#a7f3d0}
.hk-pill.r{background:rgba(248,113,113,0.22);border-color:rgba(248,113,113,0.45);color:#fecaca}

/* STAT CARDS */
.stat-row3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;margin-bottom:10px;width:100%;box-sizing:border-box;min-width:0}
.stat3{border-radius:var(--rsm);padding:10px 8px;position:relative;overflow:hidden;border:1px solid var(--glass-bdr);background:var(--glass);box-sizing:border-box;min-width:0}
.stat3-ico{font-size:1rem;margin-bottom:4px}
.stat3-val{font-family:var(--ffd);font-size:0.88rem;font-weight:700;color:#fff;line-height:1.1;word-break:break-word;margin-bottom:2px}
.stat3-lbl{font-size:0.54rem;font-weight:700;color:var(--tx3);text-transform:uppercase;letter-spacing:0.06em}
.stat3-glow{position:absolute;top:-15px;right:-15px;width:50px;height:50px;border-radius:50%;opacity:0.5;pointer-events:none}
.tap-card{cursor:pointer}

/* CHART */
.chart-card{background:var(--glass);border:1px solid var(--glass-bdr);border-radius:var(--rsm);padding:10px 12px;overflow:hidden;width:100%;box-sizing:border-box}
.bud-list{display:flex;flex-direction:column;gap:6px;width:100%}
.bud-item{background:var(--glass);border:1px solid var(--glass-bdr);border-radius:var(--rsm);padding:10px 12px;width:100%;box-sizing:border-box}
.bud-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:5px;gap:6px;min-width:0}
.bud-name{font-size:0.78rem;font-weight:700;flex:1;min-width:0;margin-right:6px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#fff}
.bud-pct{font-size:0.7rem;font-weight:800;color:var(--tx2);flex-shrink:0}
.bud-bar{height:4px;background:rgba(255,255,255,0.1);border-radius:99px;overflow:hidden}
.bud-fill{height:100%;border-radius:99px;transition:width .8s var(--ease)}
.bud-ok{background:linear-gradient(90deg,var(--grn),#60DA90)}
.bud-warn{background:linear-gradient(90deg,#fbbf24,#F0C850)}
.bud-over{background:linear-gradient(90deg,var(--red),#F09060)}
.bud-amts{display:flex;justify-content:space-between;margin-top:4px;font-size:0.65rem;color:var(--tx3)}

/* DATA PAGE */
.data-summary{display:flex;align-items:stretch;background:var(--glass);border:1px solid var(--glass-bdr);border-radius:var(--rsm);margin-bottom:10px;overflow:hidden;width:100%;box-sizing:border-box}
.ds-item{flex:1;padding:10px 4px;text-align:center;min-width:0}
.ds-sep{width:1px;background:var(--bdr);flex-shrink:0}
.ds-lbl{font-size:0.55rem;font-weight:800;color:var(--tx3);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:3px}
.ds-val{font-family:var(--ffd);font-size:0.76rem;font-weight:700;word-break:break-all}
.ds-val.g{color:var(--grn)}.ds-val.r{color:var(--red)}
.toolbar{display:flex;align-items:center;gap:5px;margin-bottom:8px;flex-wrap:nowrap;width:100%;box-sizing:border-box;min-width:0}
.srch-wrap{display:flex;align-items:center;gap:4px;background:var(--glass);border:1.5px solid var(--glass-bdr);border-radius:50px;padding:0 8px;height:28px;flex:1;min-width:0;transition:border-color .15s;box-sizing:border-box}
.srch-wrap:focus-within{border-color:var(--ac)}
.srch-wrap input{border:none;background:none;outline:none;font-family:var(--ffb)!important;font-size:16px;font-weight:500;color:#fff;flex:1;min-width:0;zoom:0.75;width:100%}
.srch-wrap input::placeholder{color:var(--tx3)}
.fsel{height:28px;padding:0 6px;border-radius:50px;border:1.5px solid var(--glass-bdr);background:var(--glass);color:#fff;font-family:var(--ffb)!important;font-size:16px;font-weight:600;cursor:pointer;appearance:none;-webkit-appearance:none;flex:1;min-width:0;zoom:0.75;box-sizing:border-box}
.dlist{display:flex;flex-direction:column;gap:6px;width:100%}
.date-group{margin-bottom:12px;width:100%;box-sizing:border-box;min-width:0}
.dg-header{display:flex;align-items:center;gap:6px;margin-bottom:6px;padding:0 2px;width:100%;min-width:0}
.dg-dot{width:6px;height:6px;border-radius:50%;background:var(--ac);flex-shrink:0}
.dg-date{font-size:0.65rem;font-weight:700;color:var(--tx2);flex:1;min-width:0}
.dg-kas{font-size:0.65rem;font-weight:800;flex-shrink:0}
.dg-kas.g{color:var(--grn)}.dg-kas.r{color:var(--red)}
.dg-cards{display:flex;flex-direction:column;gap:5px;width:100%;min-width:0}
.dc{background:var(--glass);border:1px solid var(--glass-bdr);border-radius:var(--rsm);padding:10px 12px;border-left:3px solid transparent;width:100%;box-sizing:border-box;min-width:0}
.dc.inc{background:var(--inc);border-left-color:var(--grn)}
.dc.spd{background:var(--spd);border-left-color:var(--red)}
.dc-row1{display:flex;align-items:flex-start;justify-content:space-between;gap:6px;margin-bottom:4px;width:100%;min-width:0}
.dc-kat{font-weight:700;font-size:0.84rem;flex:1;min-width:0;color:#fff;word-break:break-word}
.dc-right{flex-shrink:0;text-align:right;min-width:0}
.dc-nom{font-weight:800;font-size:0.84rem;font-family:var(--ffd);white-space:nowrap}
.dc-nom.inc{color:var(--grn)}.dc-nom.spd{color:var(--red)}
.dc-badge{display:inline-flex;align-items:center;gap:2px;font-size:0.6rem;font-weight:700;padding:2px 6px;border-radius:50px;margin-top:2px}
.dc-badge.inc{background:var(--grn-bg);color:var(--grn)}.dc-badge.spd{background:var(--red-bg);color:var(--red)}
.dc-tags{display:flex;flex-wrap:wrap;gap:4px;margin-top:5px;padding-top:5px;border-top:1px solid var(--bdr);align-items:center;min-width:0}
.dtag{font-size:0.62rem;color:var(--tx2);font-weight:600;background:rgba(255,255,255,0.1);padding:2px 6px;border-radius:50px;white-space:nowrap}
.dc-ket{font-size:0.65rem;color:var(--tx3);margin-top:3px;font-style:italic}

/* TABUNGAN */
.lock-card{background:var(--glass);border:1px solid var(--glass-bdr);border-radius:var(--r);text-align:center;padding:40px 16px;width:100%;box-sizing:border-box}
.lock-ico{font-size:2.2rem;margin-bottom:10px}
.lock-card p{color:var(--tx2);margin-bottom:14px;font-size:0.84rem}
.btn-show{padding:8px 22px;border-radius:50px;border:none;background:linear-gradient(135deg,var(--ac),var(--ac2));color:#fff;font-family:var(--ffb);font-weight:700;font-size:0.82rem;cursor:pointer;box-shadow:var(--sa)}
.btn-hide{padding:6px 14px;border-radius:50px;border:1.5px solid var(--bdr2);background:var(--glass);color:var(--tx2);font-family:var(--ffb);font-size:0.76rem;font-weight:600;cursor:pointer;margin-bottom:12px}
.hero-tab{border-radius:20px;padding:18px 16px;margin-bottom:4px;position:relative;overflow:hidden;box-shadow:0 8px 32px rgba(168,85,247,0.3);width:100%;box-sizing:border-box}
:root .hero-tab{background:linear-gradient(135deg,#4c1d95 0%,#7c3aed 45%,#be185d 100%)}
[data-theme="ocean"] .hero-tab{background:linear-gradient(135deg,#0A4A8C 0%,#1060B8 50%,#1E7CDA 100%)}
.hero-tab::before{content:'';position:absolute;top:-20px;right:-20px;width:100px;height:100px;border-radius:50%;background:rgba(255,255,255,0.08);pointer-events:none}
.ht-lbl{font-size:0.6rem;color:rgba(255,255,255,0.8);font-weight:800;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:4px}
.ht-val{font-family:var(--ffd);font-size:1.9rem;color:#fff;font-weight:700;word-break:break-word;line-height:1;margin-bottom:4px}
.ht-sub{font-size:0.65rem;color:rgba(255,255,255,0.65);margin-bottom:8px}
.ht-bar{height:4px;background:rgba(255,255,255,0.2);border-radius:99px;overflow:hidden}
.ht-bar-fill{height:100%;border-radius:99px;background:rgba(255,255,255,0.85);transition:width .8s var(--ease)}
.tlist{display:flex;flex-direction:column;gap:6px;width:100%}
.tab-item{border-radius:var(--rsm);padding:10px 12px;border:1px solid var(--glass-bdr);background:var(--glass);width:100%;box-sizing:border-box}
.tab-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;gap:6px;min-width:0}
.tab-mo{font-weight:700;font-size:0.84rem;color:#fff;display:flex;align-items:center;gap:5px;flex:1;min-width:0}
.tab-pc{font-size:0.72rem;font-weight:800;flex-shrink:0}
.tab-bar{height:4px;background:rgba(255,255,255,0.12);border-radius:99px;overflow:hidden;margin-bottom:8px}
.tab-bar-fill{height:100%;border-radius:99px;transition:width .8s var(--ease)}
.tab-amts{display:grid;grid-template-columns:1fr 1fr;gap:4px}
.tab-amt-item{text-align:center;padding:5px 4px;background:rgba(255,255,255,0.06);border-radius:7px}
.tab-amt-lbl{font-size:0.56rem;color:rgba(255,255,255,0.55);font-weight:800;text-transform:uppercase;margin-bottom:2px}
.tab-amt-val{font-size:0.78rem;font-weight:800;color:#fff}

/* TARGET */
.tgt-cur-item{border-radius:var(--rsm);padding:10px 12px;border:1px solid var(--glass-bdr);background:var(--glass);margin-bottom:5px;width:100%;box-sizing:border-box}
.tgt-cur-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;gap:6px;min-width:0}
.tgt-cur-mo{font-weight:700;font-size:0.84rem;color:#fff;flex:1;min-width:0}
.tgt-cur-val{font-weight:800;font-family:var(--ffd);font-size:0.9rem;flex-shrink:0}
.tgt-cur-bar{height:4px;background:rgba(255,255,255,0.12);border-radius:99px;overflow:hidden;margin-bottom:5px}
.tgt-cur-bar-fill{height:100%;border-radius:99px;transition:width .8s var(--ease)}
.tgt-cur-real{font-size:0.64rem;color:rgba(255,255,255,0.6);font-weight:600}

/* BOTTOM SHEET */
.bs-ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);backdrop-filter:blur(4px);z-index:500;align-items:flex-end;overflow:hidden;touch-action:none}
.bs-ov.open{display:flex}
.bs-sheet{background:rgba(20,16,50,0.97);width:100%;border-radius:var(--r) var(--r) 0 0;max-height:78vh;display:flex;flex-direction:column;animation:bsin .26s var(--ease);padding-bottom:env(safe-area-inset-bottom);overflow:hidden;touch-action:pan-y;border-top:1px solid rgba(255,255,255,0.15)}
[data-theme="ocean"] .bs-sheet{background:rgba(8,30,70,0.97)}
@keyframes bsin{from{transform:translateY(100%)}to{transform:none}}
.bs-handle{width:36px;height:4px;border-radius:99px;background:rgba(255,255,255,0.2);margin:8px auto 3px;flex-shrink:0}
