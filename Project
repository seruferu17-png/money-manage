.bnav-btn{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;background:none;border:none;cursor:pointer;color:rgba(255,255,255,0.35);transition:color .2s;padding:5px 0;position:relative;font-size:1.05rem}
